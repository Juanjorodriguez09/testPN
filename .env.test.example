# Variables de entorno para tests E2E
# Copia este archivo a .env.test y actualiza los valores según sea necesario

# Node Environment
NODE_ENV=test

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=konekt_pn_test

# JWT Configuration
JWT_SECRET=test-secret-key-do-not-use-in-production
JWT_EXPIRATION=24h

# Mail Configuration (Optional for tests)
MAIL_HOST=localhost
MAIL_PORT=1025
MAIL_USER=test@example.com
MAIL_PASSWORD=test
MAIL_FROM=test@example.com

# API Configuration
API_URL=http://localhost:3000
FRONTEND_URL=http://localhost:3000

# Otras configuraciones
PORT=3000
THROTTLE_TTL=60000
THROTTLE_LIMIT=100
